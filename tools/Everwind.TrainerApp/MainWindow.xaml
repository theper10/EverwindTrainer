                                            </Grid>
                                        </Border>
                                        <ToggleButton x:Name="XpToggle" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Tag="xp" Style="{StaticResource TrainerToggleStyle}" Checked="FeatureToggle_Changed" Unchecked="FeatureToggle_Changed" />
                                        <ToggleButton x:Name="XpPinButton" Grid.Column="5" Tag="xp" Style="{StaticResource FeaturePinButtonStyle}" Click="PinFeature_Click" />
                                    </Grid>
                                </Border>

                                <Border x:Name="SpeedRow" Style="{StaticResource FeatureRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="320" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" MinWidth="72" />
                                            <ColumnDefinition Width="42" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource IconBubbleStyle}">
                                            <Grid Width="16" Height="16"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center">
                                                <Path Data="M2,5 L7,8 L2,11 M8,5 L14,8 L8,11"
                                                      Stroke="{StaticResource MutedBrush}"
                                                      StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Movement Speed" Style="{StaticResource FeatureNameStyle}" />
                                                <Border Style="{StaticResource InfoBadgeStyle}" ToolTip="Multiplies walking, sprinting, crouching, and swimming speed. 1× is normal.">
                                                    <TextBlock Text="i" Style="{StaticResource InfoBadgeTextStyle}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Adjust walk, sprint, crouch and swim speeds" Style="{StaticResource FeatureHintStyle}" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Style="{StaticResource ValueStepperBorderStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="31" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="31" />
                                                </Grid.ColumnDefinitions>
                                                <Button Content="&#x2212;" Style="{StaticResource ValueButtonStyle}" Tag="SpeedValue|-0.1|0.1|10|2|speed" Click="StepValue_Click" />
                                                <TextBox x:Name="SpeedValue" Grid.Column="1" Text="1.5×" Tag="speed|1.5" Style="{StaticResource MultiplierValueTextStyle}" LostFocus="ValueBox_LostFocus" KeyDown="ValueBox_KeyDown" />
                                                <Button Grid.Column="2" Content="+" Style="{StaticResource ValueButtonStyle}" Tag="SpeedValue|0.1|0.1|10|2|speed" Click="StepValue_Click" />
                                            </Grid>
                                        </Border>
                                        <ToggleButton x:Name="SpeedToggle" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Tag="speed" Style="{StaticResource TrainerToggleStyle}" Checked="FeatureToggle_Changed" Unchecked="FeatureToggle_Changed" />
                                        <ToggleButton x:Name="SpeedPinButton" Grid.Column="5" Tag="speed" Style="{StaticResource FeaturePinButtonStyle}" Click="PinFeature_Click" />
                                    </Grid>
                                </Border>

                                <Border x:Name="JumpRow" Style="{StaticResource FeatureRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="320" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" MinWidth="72" />
                                            <ColumnDefinition Width="42" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource IconBubbleStyle}">
                                            <Path Width="14" Height="15"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Stretch="Uniform"
                                                  Fill="{StaticResource MutedBrush}"
                                                  Data="M8,1 L14,7 L10,7 L10,15 L6,15 L6,7 L2,7 Z" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Jump Height" Style="{StaticResource FeatureNameStyle}" />
                                                <Border Style="{StaticResource InfoBadgeStyle}" ToolTip="Multiplies how high you jump. 1× is normal.">
                                                    <TextBlock Text="i" Style="{StaticResource InfoBadgeTextStyle}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Absolute jump boost value, no compounding" Style="{StaticResource FeatureHintStyle}" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Style="{StaticResource ValueStepperBorderStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="31" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="31" />
                                                </Grid.ColumnDefinitions>
                                                <Button Content="&#x2212;" Style="{StaticResource ValueButtonStyle}" Tag="JumpValue|-0.1|0.1|10|2|jump" Click="StepValue_Click" />
                                                <TextBox x:Name="JumpValue" Grid.Column="1" Text="2×" Tag="jump|2" Style="{StaticResource MultiplierValueTextStyle}" LostFocus="ValueBox_LostFocus" KeyDown="ValueBox_KeyDown" />
                                                <Button Grid.Column="2" Content="+" Style="{StaticResource ValueButtonStyle}" Tag="JumpValue|0.1|0.1|10|2|jump" Click="StepValue_Click" />
                                            </Grid>
                                        </Border>
                                        <ToggleButton x:Name="JumpToggle" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Tag="jump" Style="{StaticResource TrainerToggleStyle}" Checked="FeatureToggle_Changed" Unchecked="FeatureToggle_Changed" />
                                        <ToggleButton x:Name="JumpPinButton" Grid.Column="5" Tag="jump" Style="{StaticResource FeaturePinButtonStyle}" Click="PinFeature_Click" />
                                    </Grid>
                                </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid Style="{StaticResource SectionHeaderBarStyle}"
                                      Tag="InventoryOptionsPanel|InventorySectionToggleButton"
                                      MouseLeftButtonDown="SectionHeader_MouseLeftButtonDown"
                                      ToolTip="Collapse or expand Inventory">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource IconBubbleStyle}" Background="#131820">
                                        <Grid Width="15" Height="15"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition />
                                                <RowDefinition />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Margin="0,0,1.5,1.5" Fill="{StaticResource SoftTextBrush}" />
                                            <Rectangle Grid.Column="1" Margin="1.5,0,0,1.5" Fill="{StaticResource SoftTextBrush}" />
                                            <Rectangle Grid.Row="1" Margin="0,1.5,1.5,0" Fill="{StaticResource SoftTextBrush}" />
                                            <Rectangle Grid.Row="1" Grid.Column="1" Margin="1.5,1.5,0,0" Fill="{StaticResource SoftTextBrush}" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="INVENTORY"
                                               Style="{StaticResource SectionLabelStyle}"
                                               Margin="12,0,0,0" />
                                    <ToggleButton x:Name="InventorySectionToggleButton"
                                                  Grid.Column="2"
                                                  VerticalAlignment="Center"
                                                  Tag="InventoryOptionsPanel"
                                                  Style="{StaticResource SectionToggleButtonStyle}"
                                                  IsHitTestVisible="False"
                                                  Focusable="False" />
                                </Grid>

                                <StackPanel x:Name="InventoryOptionsPanel">
                                <Border x:Name="NoDurabilityRow" Style="{StaticResource FeatureRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="320" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" MinWidth="72" />
                                            <ColumnDefinition Width="42" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource IconBubbleStyle}">
                                            <Grid Width="16" Height="16"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center">
                                                <Path Data="M8,1.5 L14,4 V8 C14,11.5 11.7,14 8,15 C4.3,14 2,11.5 2,8 V4 Z"
                                                      Stroke="{StaticResource MutedBrush}"
                                                      StrokeThickness="1.5"
                                                      StrokeLineJoin="Round" />
                                                <Path Data="M4.5,8 L7,10.5 L11.5,6"
                                                      Stroke="{StaticResource MutedBrush}"
                                                      StrokeThickness="1.5"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Infinite Durability" Style="{StaticResource FeatureNameStyle}" />
                                                <Border Style="{StaticResource InfoBadgeStyle}" ToolTip="Prevents tools and equipment from losing durability.">
                                                    <TextBlock Text="i" Style="{StaticResource InfoBadgeTextStyle}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Keep tools and equipment from losing durability" Style="{StaticResource FeatureHintStyle}" />
                                        </StackPanel>
                                        <ToggleButton x:Name="NoDurabilityToggle" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Tag="noDurability" Style="{StaticResource TrainerToggleStyle}" Checked="FeatureToggle_Changed" Unchecked="FeatureToggle_Changed" />
                                        <ToggleButton x:Name="NoDurabilityPinButton" Grid.Column="5" Tag="noDurability" Style="{StaticResource FeaturePinButtonStyle}" Click="PinFeature_Click" />
                                    </Grid>
                                </Border>

                                <Border x:Name="DurabilityRow" Style="{StaticResource FeatureRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="320" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" MinWidth="72" />
                                            <ColumnDefinition Width="42" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource IconBubbleStyle}">
                                            <Path Width="15" Height="15"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Stretch="Uniform"
                                                  Fill="{StaticResource MutedBrush}"
                                                  Data="M22.7,19 L13.6,9.9 C14.5,7.6 14,4.9 12.1,3 C10.1,1 7.1,0.6 4.7,1.7 L9,6 L6,9 L1.7,4.7 C0.5,7.1 0.9,10.1 2.9,12.1 C4.8,14 7.5,14.5 9.8,13.6 L18.9,22.7 C20,23.8 21.7,23.8 22.8,22.7 C23.8,21.7 23.8,20 22.7,19 Z" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Durability Loss Rate" Style="{StaticResource FeatureNameStyle}" />
                                                <Border Style="{StaticResource InfoBadgeStyle}" ToolTip="Controls how quickly durability is lost. Lower values make items last longer; 1× is normal.">
                                                    <TextBlock Text="i" Style="{StaticResource InfoBadgeTextStyle}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Fine-tune item wear rate" Style="{StaticResource FeatureHintStyle}" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Style="{StaticResource ValueStepperBorderStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="31" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="31" />
                                                </Grid.ColumnDefinitions>
                                                <Button Content="&#x2212;" Style="{StaticResource ValueButtonStyle}" Tag="DurabilityValue|-0.1|0|10|2|durability" Click="StepValue_Click" />
                                                <TextBox x:Name="DurabilityValue" Grid.Column="1" Text="1×" Tag="durability|1" Style="{StaticResource MultiplierValueTextStyle}" LostFocus="ValueBox_LostFocus" KeyDown="ValueBox_KeyDown" />
                                                <Button Grid.Column="2" Content="+" Style="{StaticResource ValueButtonStyle}" Tag="DurabilityValue|0.1|0|10|2|durability" Click="StepValue_Click" />
                                            </Grid>
                                        </Border>
                                        <ToggleButton x:Name="DurabilityToggle" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Tag="durability" Style="{StaticResource TrainerToggleStyle}" Checked="FeatureToggle_Changed" Unchecked="FeatureToggle_Changed" />
                                        <ToggleButton x:Name="DurabilityPinButton" Grid.Column="5" Tag="durability" Style="{StaticResource FeaturePinButtonStyle}" Click="PinFeature_Click" />
                                    </Grid>
                                </Border>

                                <Border x:Name="ItemAmountRow" Style="{StaticResource FeatureRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="320" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" MinWidth="72" />
                                            <ColumnDefinition Width="42" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource IconBubbleStyle}">
                                            <Canvas Width="16" Height="16"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                <Rectangle Canvas.Left="1" Canvas.Top="1.5"
                                                           Width="10" Height="9"
                                                           RadiusX="1.5" RadiusY="1.5"
                                                           Stroke="{StaticResource MutedBrush}"
                                                           StrokeThickness="1.5" />
                                                <Rectangle Canvas.Left="5" Canvas.Top="5.5"
                                                           Width="10" Height="9"
                                                           RadiusX="1.5" RadiusY="1.5"
                                                           Fill="#131820"
                                                           Stroke="{StaticResource MutedBrush}"
                                                           StrokeThickness="1.5" />
                                            </Canvas>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" ClipToBounds="True">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="[Slot 1] Minimum Stack Size" Style="{StaticResource FeatureNameStyle}" />
                                                <Border Style="{StaticResource InfoBadgeStyle}" ToolTip="Raises the item stack in [Slot 1] to this number once. [Slot 1] must already contain an item. Click Apply whenever you want to run it.">
                                                    <TextBlock Text="i" Style="{StaticResource InfoBadgeTextStyle}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Raise only [Slot 1] up to this minimum" Style="{StaticResource FeatureHintStyle}" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Style="{StaticResource ValueStepperBorderStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="31" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="31" />
                                                </Grid.ColumnDefinitions>
                                                <Button Content="&#x2212;" Style="{StaticResource ValueButtonStyle}" Tag="ItemAmountValue|-1|1|9999|0|itemAmount" Click="StepValue_Click" />
                                                <TextBox x:Name="ItemAmountValue" Grid.Column="1" Text="99" Tag="itemAmount|99" Style="{StaticResource ValueTextStyle}" LostFocus="ValueBox_LostFocus" KeyDown="ValueBox_KeyDown" />
                                                <Button Grid.Column="2" Content="+" Style="{StaticResource ValueButtonStyle}" Tag="ItemAmountValue|1|1|9999|0|itemAmount" Click="StepValue_Click" />
                                            </Grid>
                                        </Border>
                                        <Button x:Name="ItemAmountApplyButton"
                                                Grid.Column="3"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource ApplyActionButtonStyle}"
                                                Click="ItemAmountApply_Click">
                                            <TextBlock Text="&#x2713;"
                                                       FontSize="16"
                                                       FontWeight="Black"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,-1,0,0" />
                                        </Button>
                                        <ToggleButton x:Name="ItemAmountPinButton" Grid.Column="5" Tag="itemAmount" Style="{StaticResource FeaturePinButtonStyle}" Click="PinFeature_Click" />
                                    </Grid>
                                </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
