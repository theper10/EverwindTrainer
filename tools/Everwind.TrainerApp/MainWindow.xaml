<Window x:Class="Everwind.TrainerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Everwind Trainer"
        Width="1040"
        Height="790"
        MinWidth="920"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#07090D"
        Foreground="#F1F3F5"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="1"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#D7C46A" />
        <SolidColorBrush x:Key="AccentHotBrush" Color="#E8DB9A" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#6E6441" />
        <SolidColorBrush x:Key="TextBrush" Color="#F1F3F5" />
        <SolidColorBrush x:Key="SoftTextBrush" Color="#B9C0C8" />
        <SolidColorBrush x:Key="MutedBrush" Color="#858D98" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#242A32" />
        <SolidColorBrush x:Key="BorderBrushHot" Color="#3A424C" />
        <SolidColorBrush x:Key="InputBrush" Color="#10141A" />
        <SolidColorBrush x:Key="DangerBrush" Color="#D66A73" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#6FB98D" />
        <SolidColorBrush x:Key="WarningBrush" Color="#D0A15A" />

        <LinearGradientBrush x:Key="ChromeBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#111820" Offset="0" />
            <GradientStop Color="#0E1218" Offset="0.65" />
            <GradientStop Color="#0B0E13" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F141A" Offset="0" />
            <GradientStop Color="#0B0F14" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="RowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#B010151B" Offset="0" />
            <GradientStop Color="#940D1116" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="RowHoverBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#CC151B22" Offset="0" />
            <GradientStop Color="#B811161D" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#E1D18A" Offset="0" />
            <GradientStop Color="#D2BD5B" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="AppFrameStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="CardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="18,10,18,2" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="FeatureRowStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource RowBrush}" />
            <Setter Property="BorderBrush" Value="#7020262E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="17" />
            <Setter Property="Height" Value="62" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHoverBrush}" />
                    <Setter Property="BorderBrush" Value="#9A3E4855" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FeaturePinButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="#151B23" />
            <Setter Property="BorderBrush" Value="#252D37" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#7E8895" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="ToolTip" Value="Pin feature" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Path x:Name="PinIcon"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  Fill="{TemplateBinding Foreground}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M8,1 L14,7 L11.8,9.2 L15,12.4 L12.4,15 L9.2,11.8 L4.2,16.8 L3.2,15.8 L8.2,10.8 L5,7.6 L7.6,5 L1,3 L3,1 Z" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E2631" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4A5563" />
                                <Setter Property="Foreground" Value="{StaticResource SoftTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3F3516" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D7C46A" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter Property="ToolTip" Value="Unpin feature" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="{StaticResource SoftTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionHeaderBarStyle" TargetType="{x:Type Grid}">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Background" Value="#3211161D" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A17202A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Background" Value="#131820" />
            <Setter Property="BorderBrush" Value="#29313B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="Collapse section" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <Grid x:Name="ChevronIcon"
                                  Width="14"
                                  Height="14"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </Grid.RenderTransform>
                                <Path Data="M3,6 L7,2.5 L11,6"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                                <Path Data="M3,11.5 L7,8 L11,11.5"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1A212A" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3A4654" />
                                <Setter Property="Foreground" Value="{StaticResource AccentHotBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#222B35" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChevronIcon" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FeatureNameStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="FeatureHintStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>

        <Style x:Key="IconBubbleStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Background" Value="#131820" />
            <Setter Property="BorderBrush" Value="#252B34" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="InfoBadgeStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="9,0,0,0" />
            <Setter Property="Background" Value="#453A17" />
            <Setter Property="BorderBrush" Value="#6A5720" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="120" />
        </Style>

        <Style x:Key="InfoBadgeTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#F3D875" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Placement" Value="Mouse" />
            <Setter Property="MaxWidth" Value="320" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToolTip}">
                        <Border Background="#151A21"
                                BorderBrush="#39424D"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12,9"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  BlurRadius="14"
                                                  ShadowDepth="3"
                                                  Opacity="0.48" />
                            </Border.Effect>
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="#E7EBF0"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       LineHeight="18" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusPillStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#101419" />
            <Setter Property="BorderBrush" Value="#242B34" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="DropPoolStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="238" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="#101419" />
            <Setter Property="BorderBrush" Value="#2A313B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="AllowDrop" Value="True" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#6F6847" />
                    <Setter Property="Background" Value="#131820" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="48" />
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3478F6" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3478F6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#1E4FAF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1E4FAF" />
                                <Setter TargetName="Root" Property="Opacity" Value="0.88" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="#AEB9C6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1C2734" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#263545" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource WindowButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CleanScrollRepeatButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CleanScrollThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbRoot"
                                Width="5"
                                Margin="2,6,2,6"
                                HorizontalAlignment="Center"
                                Background="#343D48"
                                CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Width" Value="7" />
                                <Setter TargetName="ThumbRoot" Property="Background" Value="#66717E" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbRoot" Property="Width" Value="7" />
                                <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="10" />
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Root"
                              Background="Transparent"
                              Width="{TemplateBinding Width}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource CleanScrollRepeatButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource CleanScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource CleanScrollRepeatButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1F10161E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrainerToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="78" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Grid Width="78" Height="34">
                            <Border x:Name="Track"
                                    Background="#222B35"
                                    CornerRadius="17"
                                    BorderBrush="#343B45"
                                    BorderThickness="1" />
                            <TextBlock x:Name="StateText"
                                       Text="OFF"
                                       FontSize="10"
                                       FontWeight="Black"
                                      Foreground="#8390A0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <Ellipse x:Name="Thumb"
                                     Width="22"
                                     Height="22"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="7,0,0,0"
                                     Fill="#A9B0B9" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#4A525D" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentGradientBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#D9C977" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,7,0" />
                                <Setter TargetName="Thumb" Property="Fill" Value="#0B0D10" />
                                <Setter TargetName="StateText" Property="Text" Value="ON" />
                                <Setter TargetName="StateText" Property="Foreground" Value="#0B0D10" />
                                <Setter TargetName="StateText" Property="HorizontalAlignment" Value="Left" />
                                <Setter TargetName="StateText" Property="Margin" Value="12,0,0,0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ApplyActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="{StaticResource AccentGradientBrush}" />
            <Setter Property="BorderBrush" Value="#D9C977" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#0B0D10" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHotBrush}" />
                                <Setter TargetName="Root" Property="Opacity" Value="0.96" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.84" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ValueStepperBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="130" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="#242B34" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="17" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0,12,0" />
        </Style>

        <Style x:Key="ValueButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="31" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1A2028" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#222933" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

